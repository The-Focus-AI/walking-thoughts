# Development and Preview use a dedicated Clerk development instance (pk_test/sk_test).
# Production must use a separate production instance (pk_live/sk_live) on its custom domain.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Comma-separated stable Clerk user IDs. At least one is required; fail closed otherwise.
CLERK_ALLOWED_USER_IDS=

# Existing preview Clerk users used by the authenticated public-surface test.
CLERK_E2E_ALLOWED_EMAIL=
CLERK_E2E_DISALLOWED_EMAIL=

# Production: exact custom application origin. Preview may use a stable alias.
CLERK_AUTHORIZED_PARTIES=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon Postgres for synchronized Threads. When unset, the API uses an
# in-process memory repository suitable for local/tests only.
DATABASE_URL=

# Vercel Blob token for private media. When unset, sync uses an in-process
# private blob store suitable for local/tests only.
BLOB_READ_WRITE_TOKEN=

# Public Vercel Blob store token used only by `mise run region:publish`.
# Keep this separate from BLOB_READ_WRITE_TOKEN (private media).
BLOB_REGION_READ_WRITE_TOKEN=

# Public base URL for the home Offline Region pack (no trailing slash).
# When set, /journal defaults to the Blob-hosted home pack (~40 km).
# Example: https://<store>.public.blob.vercel-storage.com/offline-region/home
NEXT_PUBLIC_OFFLINE_REGION_HOME_BASE=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Vercel AI Gateway for Enrichments. When unset, the API uses a local fake gateway for tests/dev.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=anthropic/claude-sonnet-5

# Optional web search for Enrichments. When unset, local dev uses a fake
# search client; real-model environments (production/gateway) skip search.
TAVILY_API_KEY=
# Optional: set to nominatim to reverse-geocode Capture locations online.
ENRICHMENT_GEOCODER=

# Web Push (VAPID). When unset, Enrichment still runs; push delivery is skipped.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:wschenk@thefocus.ai
